<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Order Confirmation - GameVault</title>
    <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@500;600;700&family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/global.css">
    <link rel="stylesheet" href="/css/confirmation.css">
    <link rel="icon" type="image/png" href="/images/favi.png">
</head>
<body>
    <!-- Navbar -->
    <nav class="navbar">
        <a href="/" class="logo">
            <span class="logo-icon"><img src="/images/favi.png" alt="" width="30px" height="30px"></span>
            Game<span>Vault</span>
        </a>

        <ul class="nav-links">
            <li><a href="/">Home</a></li>
            <li><a href="/games">Games</a></li>
            <li><a href="/support/support">Contact</a></li>
            <% if (user && user.role === 'admin') { %>
                <li><a href="/admin-dashboard">Dashboard</a></li>
            <% } %>
        </ul>

        <div class="nav-actions">
            <div class="auth-buttons">
                <% if (locals.user) { %>
                    <form action="/logout" method="get" class="logout-form">
                        <button type="submit" class="btn btn-login">Logout</button>
                    </form>
                <% } else { %>
                    <a href="/login" class="btn btn-login">Login</a>
                    <a href="/register" class="btn btn-register">Register</a>
                <% } %>
            </div>
        </div>

        <div class="hamburger">
            <div class="line1"></div>
            <div class="line2"></div>
            <div class="line3"></div>
        </div>
    </nav>

    <div class="container">
        <h1>🎉 Thank you, <%= user.name %>!</h1>
        <p>Your order has been placed successfully.</p>
        <p><strong>Billing ID:</strong> <%= billingInfo.bill_id %></p>
        <p><strong>Status:</strong> <%= billingInfo.o_status %></p>
       <% 
    let subtotal = 0;
    items.forEach(item => {
        subtotal += item.price * item.quantity;
    });
    let taxRate = 0.10;
    let tax = subtotal * taxRate;
    let total = subtotal + tax;
%>


<p><strong>Total Paid:</strong> $<%= total.toFixed(2) %></p>

        <p>Your tracking number: <%= billingInfo.tracking_number %></p>


        <table>
            <thead>
                <tr>
                    <th>Product</th>
                    <th>Qty</th>
                    <th>Price</th>
                    <th>Subtotal</th>
                </tr>
            </thead>
            <tbody>
                <% items.forEach(item => { %>
                    <tr>
                        <td><%= item.name %></td>
                        <td><%= item.quantity %></td>
                        <td>$<%= item.price.toFixed(2) %></td>
                        <td>$<%= (item.price * item.quantity).toFixed(2) %></td>
                    </tr>
                <% }) %>
            </tbody>
        </table>

        <a href="/" class="btn">Return to Home</a>
    </div>
    <script src="/js/nav.js"></script>
</body>
</html>
