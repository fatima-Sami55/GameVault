<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Manage Products - GameVault</title>
    <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@500;600;700&family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/global.css">
    <link rel="stylesheet" href="/css/admin.css">
    <link rel="stylesheet" href="/css/manageproducts.css">
    <link rel="icon" type="image/png" href="/images/favi.png">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
</head>
<body>
    <!-- Sidebar -->
    <div class="sidebar">
        <a href="/" class="logo">
            <img src="/images/favi.png" alt="GameVault">
            <div class="logo-content">
                <span class="logo-text">GameVault</span>
                <span class="logo-badge">Admin</span>
            </div>
        </a>
        <ul class="nav-links">
            <li><a href="/admin-dashboard"><i class="fas fa-tachometer-alt"></i> Dashboard</a></li>
            <li><a href="/home"><i class="fas fa-home"></i> Home</a></li>
            <li><a href="/admin-user"><i class="fas fa-users"></i> Users</a></li>
            <li><a href="/admin-products"><i class="fas fa-box"></i> Add Products</a></li>
            <li class="active"><a href="/admin-products/manage"><i class="fas fa-cogs"></i> Manage Products</a></li>
            <li class="logout"><a href="/logout"><i class="fas fa-sign-out-alt"></i> Logout</a></li>
        </ul>
    </div>

    <!-- Main Content -->
    <div class="main-content">
        <div class="admin-header">
            <div class="header-left">
                <h1>Manage Products</h1>
                <p>View, edit, or delete products.</p>
            </div>
            <div class="header-right">
                <div class="user-welcome">
                    <i class="fas fa-user-circle avatar-icon"></i>
                    <span>Welcome back, <%= user.name %>!</span>
                </div>
            </div>
        </div>

        <section class="products-table">
            <% if (products.length > 0) { %>
                <table>
                    <thead>
                        <tr>
                            <th>ID</th>
                            <th>Image</th>
                            <th>Name</th>
                            <th>Price</th>
                            <th>Stock</th>
                            <th>Genre</th>
                            <th>Actions</th>
                           
                        </tr>
                    </thead>
                    <tbody>
                        <% products.forEach(product => { %>
                            <tr>
                                <td><%= product.pid %></td> 
                                <th><img src="<%= product.img.startsWith('http') ? product.img : '/uploads/' + product.img %>" alt="" width="80px" height="80px"></th>
                                <td><%= product.name %></td>
                                <td>$<%= product.price.toFixed(2) %></td>
                                <td><%= product.status %></td>
                                <td><%= product.genre %></td>
                                <td>
                                    <div class="action-buttons">
                                        <a href="/products/edit/<%= product.pid %>" class="btn btn-edit">Edit</a>
                                        <form action="/products/delete/<%= product.pid %>" method="POST" class="delete-form">
                                            <button type="submit" class="btn btn-delete" onclick="return confirm('Are you sure you want to delete this product?')">Delete</button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        <% }); %>
                    </tbody>
                </table>
            <% } else { %>
                <p>No products available.</p>
            <% } %>
        </section>
    </div>

    <!-- Hamburger Menu -->
    <div class="hamburger">
        <span></span>
        <span></span>
        <span></span>
    </div>

    <script src="/js/nav.js"></script>
    <script>
        document.addEventListener('DOMContentLoaded', () => {
            const hamburger = document.querySelector('.hamburger');
            if (hamburger) {
                hamburger.addEventListener('click', function () {
                    document.querySelector('.sidebar').classList.toggle('active');
                    document.querySelector('.main-content').classList.toggle('sidebar-active');
                    this.classList.toggle('active');
                });
            }
        });
    </script>
</body>
</html>
