<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Admin Dashboard</title>
    <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@500;600;700&family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/global.css">
    <link rel="stylesheet" href="/css/admin.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="icon" type="image/png" href="/images/favi.png">
</head>
<body>

    <!-- Sidebar -->
    <div class="sidebar">
        <a href="/" class="logo">
            <img src="/images/favi.png" alt="GameVault">
            <div class="logo-content">
                <span class="logo-text">GameVault</span>
                <span class="logo-badge">Admin</span>
            </div>
        </a>
        <ul class="nav-links">
            <li class="active"><a href="/admin-dashboard"><i class="fas fa-tachometer-alt"></i> Dashboard</a></li>
            <li><a href="/home"><i class="fas fa-home"></i> Home</a></li>
            <li><a href="/admin-user"><i class="fas fa-users"></i> Users</a></li>
            <li><a href="/admin-products"><i class="fas fa-box"></i> Add Products</a></li>
            <li><a href="/admin-products/manage"><i class="fas fa-cogs"></i> Manage Products</a></li>
            <li class="logout"><a href="/logout"><i class="fas fa-sign-out-alt"></i> Logout</a></li>
        </ul>
    </div>

    <!-- Main Content -->
    <div class="main-content">
        <div class="admin-header">
            <div class="header-left">
                <h1>Admin Dashboard</h1>
                <p class="date-time"><%= currentDate %> | <%= currentTime %></p>
            </div>
            <div class="header-right">
                <div class="user-welcome">
                    <i class="fas fa-user-circle avatar-icon"></i>
                    <span>Welcome back, <%= user.name || 'Admin' %>!</span>
                </div>
            </div>
        </div>

        <div class="dashboard-summary">
            <h2>Overview</h2>
            <p>Here's what's happening with your application today.</p>
        </div>

        <div class="cards">
            <div class="card">
                <div class="card-icon">
                    <i class="fas fa-users"></i>
                </div>
                <div class="card-content">
                    <div class="card-title">Total Users</div>
                    <div class="card-info"><%= stats.totalUsers %></div>
                </div>
            </div>
            <div class="card">
                <div class="card-icon">
                    <i class="fas fa-user-plus"></i>
                </div>
                <div class="card-content">
                    <div class="card-title">New Registrations</div>
                    <div class="card-info"><%= stats.newRegistrations %></div>
                </div>
            </div>
            <div class="card">
                <div class="card-icon">
                    <i class="fas fa-dollar-sign"></i>
                </div>
                <div class="card-content">
                    <div class="card-title">Total Revenue</div>
                    <div class="card-info">$<%= stats.totalRevenue.toLocaleString() %></div>
                </div>
            </div>
        </div>
        <div class="recent-activity">
            <h2>Recent Activity</h2>
            <div class="activity-list">
               <% activities.forEach((activity, index) => { %>
                    <div class="activity-item <%= index >= 7 ? 'hidden-activity' : '' %>" style="<%= index >= 7 ? 'display: none;' : '' %>">
                        <div class="activity-icon">
                            <i class="fas fa-<%= activity.type %>"></i>
                        </div>
                        <div class="activity-details">
                            <h3><%= activity.description %></h3>
                            <span class="activity-time"><%= new Date(activity.timestamp).toLocaleString() %></span>
                        </div>
                    </div>
                <% }) %>
            </div>
            <% if (activities.length > 7) { %>
                <div style="text-align: center; margin-top: 1.5rem;">
                    <button id="see-more-btn" class="btn btn-login" style="width: auto; padding: 0.6rem 2rem; border-radius: 50px; background: var(--accent); color: white; border: none; cursor: pointer; font-weight: 600;">See More</button>
                </div>
            <% } %>
        </div>
    </div>

    <!-- Hamburger Menu -->
    <div class="hamburger">
        <span></span>
        <span></span>
        <span></span>
    </div>

    <script>
        document.addEventListener('DOMContentLoaded', () => {
            const hamburger = document.querySelector('.hamburger');
            if (hamburger) {
                hamburger.addEventListener('click', () => {
                    document.querySelector('.sidebar').classList.toggle('active');
                    document.querySelector('.main-content').classList.toggle('sidebar-active');
                    hamburger.classList.toggle('active');
                });
            }

            const seeMoreBtn = document.getElementById('see-more-btn');
            if (seeMoreBtn) {
                seeMoreBtn.addEventListener('click', function() {
                    document.querySelectorAll('.hidden-activity').forEach(item => {
                        item.style.display = 'flex';
                    });
                    seeMoreBtn.parentElement.style.display = 'none';
                });
            }
        });
    </script>
    <script src="/js/nav.js"></script>
</body>
</html>
