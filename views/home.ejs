<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>GameVault - Ultimate Game Store</title>
    <link
      href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@500;600;700&family=Poppins:wght@300;400;500;600;700;800&display=swap"
      rel="stylesheet"
    />
    <link rel="stylesheet" href="/css/global.css" />
    <link rel="stylesheet" href="/css/home.css" />
    <link rel="icon" type="image/png" href="/images/favi.png" />
  </head>
  <body>
    <!-- Navbar -->
    <nav class="navbar">
      <a href="/" class="logo">
        <span class="logo-icon"
          ><img src="/images/favi.png" alt="" width="30px" height="30px"
        /></span>
        Game<span>Vault</span>
      </a>

      <ul class="nav-links">
        <li><a href="/games">Games</a></li>
        <li><a href="/support/support">Contact</a></li>
        <% if (user && user.role === 'admin') { %>
        <li><a href="/admin-dashboard">Dashboard</a></li>
        <% } %>
      </ul>

      <div class="nav-actions">
        <!-- Cart Icon with Counter -->
        <a href="/cart" class="cart-icon-wrapper">
          <div class="cart-icon">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="24"
              height="24"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <circle cx="9" cy="21" r="1"></circle>
              <circle cx="20" cy="21" r="1"></circle>
              <path
                d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"
              ></path>
            </svg>
            <span class="cart-count" id="cart-count">0</span>
          </div>
        </a>

        <div class="auth-buttons">
          <% if (locals.user) { %>
          <!-- User is logged in, show welcome message and logout button -->
          <span class="user-welcome">Welcome, <%= user.name %></span>
          <form action="/logout" method="get" class="logout-form">
            <button type="submit" class="btn btn-login">Logout</button>
          </form>
          <% } else { %>
          <!-- User is not logged in, show login and register buttons -->
          <a href="/login" class="btn btn-login">Login</a>
          <a href="/register" class="btn btn-register">Register</a>
          <% } %>
        </div>
      </div>

      <div class="hamburger">
        <div class="line1"></div>
        <div class="line2"></div>
        <div class="line3"></div>
      </div>
    </nav>

    <!-- Faint ambient grid background -->
    <div class="hero-grid-bg"></div>

    <!-- Hero Section (Three-Column symmetric layout) -->
    <section class="hero">
      <!-- Left Column: Main Content -->
      <div class="hero-content">
        <h1 class="hero-title">
          Discover Your Next <span>Gaming</span> Adventure
        </h1>
        <p class="hero-subtitle">
          Explore thousands of games across all platforms. From AAA titles to
          indie gems, find your perfect match with exclusive deals and instant
          downloads.
        </p>
        <div class="cta-buttons">
          <a href="/games" class="btn btn-cta"
            >Browse Games <span class="arrow">&rarr;</span></a
          >
          <a href="/games" class="btn btn-cta-secondary">Watch Showcase</a>
        </div>

        <!-- Trust/context badges row -->
        <div class="hero-trust-badges">
          <span class="badge-item">
            <svg
              class="badge-svg"
              width="16"
              height="16"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
            >
              <line x1="6" y1="12" x2="10" y2="12"></line>
              <line x1="8" y1="10" x2="8" y2="14"></line>
              <line x1="15" y1="13" x2="15.01" y2="13"></line>
              <line x1="18" y1="11" x2="18.01" y2="11"></line>
              <path
                d="M12 3a9 9 0 0 0-9 9c0 2 1.5 3 3.5 3.5S8.5 17 9 19a1 1 0 0 0 1 1h4a1 1 0 0 0 1-1c.5-2 2-2.5 3-3.5s3.5-1.5 3.5-3.5a9 9 0 0 0-9-9z"
              ></path>
            </svg>
            10,000+ Games
          </span>
          <span class="badge-separator">·</span>
          <span class="badge-item">
            <svg
              class="badge-svg"
              width="16"
              height="16"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
            >
              <polygon
                points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"
              ></polygon>
            </svg>
            Instant Delivery
          </span>
          <span class="badge-separator">·</span>
          <span class="badge-item">
            <svg
              class="badge-svg"
              width="16"
              height="16"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
            >
              <rect x="3" y="11" width="18" height="11" rx="2" ry="2"></rect>
              <path d="M7 11V7a5 5 0 0 1 10 0v4"></path>
            </svg>
            Secure Checkout
          </span>
        </div>
      </div>

      <!-- Right Column: Hero Character -->
      <div class="hero-char-wrapper">
        <div class="hero-char-glow"></div>
        <!-- Large screens: character points left toward the copy -->
        <img
          src="/images/mario_hero.png"
          alt="GameVault hero character"
          class="hero-char-img hero-char-lg"
        />
        <!-- Small screens: character points up toward the copy above it -->
        <img
          src="/images/mario2.png"
          alt="GameVault hero character"
          class="hero-char-img hero-char-sm"
        />
      </div>

      <!-- Decorative elements -->
      <div class="circle circle-1"></div>
      <div class="circle circle-2"></div>
    </section>

    <!-- Featured Games Section -->
    <section class="featured-games">
      <div class="section-header">
        <h2 class="Featured"><span>Games - Coming Soon</span></h2>
        <a href="/games" class="view-all">View All Games</a>
      </div>
      <% if (games && games.length) { %>
      <div class="games-grid">
        <% games.forEach(game => { %>
        <div class="game-card">
          <div class="game-image">
            <img src="<%= game.image %>" alt="<%= game.title %>" />
          </div>
          <div class="game-info">
            <h3><%= game.title %></h3>
            <div class="genre-tags">
              <% (game.genre || '').split(',').map(g => g.trim()).filter(Boolean).forEach(g => { %>
                <span class="genre-badge"><%= g %></span>
              <% }) %>
            </div>
            <p class="price"><%= game.price %></p>
            <p class="description"><%= game.description %></p>
          </div>
        </div>
        <% }) %>
      </div>
      <% } else { %>
      <p class="coming-soon-empty">
        No games are coming soon right now. Check back later!
      </p>
      <% } %>
    </section>

    <script src="/js/nav.js"></script>
  </body>
</html>
