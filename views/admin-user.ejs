<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Game Vault Admin - Manage Users</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@500;600;700&family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/global.css">
    <link rel="stylesheet" href="/css/admin.css">
    <link rel="stylesheet" href="/css/users.css">
    <link rel="icon" type="image/png" href="/images/favi.png">
</head>
<body>
    <!-- Sidebar -->
    <div class="sidebar">
        <a href="/" class="logo">
            <img src="/images/favi.png" alt="GameVault">
            <div class="logo-content">
                <span class="logo-text">GameVault</span>
                <span class="logo-badge">Admin</span>
            </div>
        </a>
        <ul class="nav-links">
            <li><a href="/admin-dashboard"><i class="fas fa-tachometer-alt"></i> Dashboard</a></li>
            <li><a href="/home"><i class="fas fa-home"></i> Home</a></li>
            <li class="active"><a href="/admin-user"><i class="fas fa-users"></i> Users</a></li>
            <li><a href="/admin-products"><i class="fas fa-box"></i> Add Products</a></li>
            <li><a href="/admin-products/manage"><i class="fas fa-cogs"></i> Manage Products</a></li>
            <li class="logout"><a href="/logout"><i class="fas fa-sign-out-alt"></i> Logout</a></li>
        </ul>
    </div>

    <!-- Main Content -->
    <div class="main-content">
        <div class="admin-header">
            <div class="header-left">
                <h1>Manage Users</h1>
                <p>Edit users role or delete users accounts.</p>
            </div>
            <div class="header-right">
                <div class="user-welcome">
                    <i class="fas fa-user-circle avatar-icon"></i>
                    <span>Welcome back, <%= user.name %>!</span>
                </div>
            </div>
        </div>

    <!-- Users Table -->
    <% const regularUsers = users.filter(u => u.role === 'user'); %>

    <% if (regularUsers.length > 0) { %>
        <div class="users-table">
            <table>
                <thead>
                    <tr>
                        <th>ID</th>
                        <th>Name</th>
                        <th>Email</th>
                        <th>Role</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    <% regularUsers.forEach(user => { %>
                        <tr>
                            <td><%= user.uuid %></td>
                            <td><%= user.name %></td>
                            <td><%= user.email %></td>
                            <td><%= user.role %></td>
                            <td>
                                <div class="btn-container">
                                 <form method="POST" action="/admin-user/makeAdmin" class="make-admin-form">
    <input type="hidden" name="uuid" value="<%= user.uuid %>">
    <button type="submit" class="btn btn-makeadmin"><i class="fas fa-person"></i> Make Admin</button>
</form>

<form method="POST" action="/admin-user/delete" class="delete-user-form">
    <input type="hidden" name="uuid" value="<%= user.uuid %>">
    <button type="submit" class="btn btn-delete"><i class="fas fa-trash"></i> Delete</button>
</form>
                                </div>
                            </td>
                        </tr>
                    <% }); %>
                </tbody>
            </table>
        </div>
    <% } else { %>
        <p style="text-align: center;">No users exsist.</p>
    <% } %>
    <!-- Main Content Close -->
    </div>

    <!-- Hamburger Menu -->
    <div class="hamburger">
        <span></span>
        <span></span>
        <span></span>
    </div>

    <!-- Footer removed for admin layout -->

    <script src="/js/nav.js"></script>
    <script>
        document.querySelectorAll('.make-admin-form').forEach(form => {
            form.addEventListener('submit', function (event) {
                event.preventDefault();
                if (confirm("Are you sure you want to make this user an admin?")) {
                    form.submit();
                }
            });
        });

        document.querySelectorAll('.delete-user-form').forEach(form => {
            form.addEventListener('submit', function (event) {
                event.preventDefault();
                if (confirm("Are you sure you want to delete this user?")) {
                    form.submit();
                }
            });
        });

        document.addEventListener('DOMContentLoaded', () => {
            const hamburger = document.querySelector('.hamburger');
            if (hamburger) {
                hamburger.addEventListener('click', function () {
                    document.querySelector('.sidebar').classList.toggle('active');
                    document.querySelector('.main-content').classList.toggle('sidebar-active');
                    this.classList.toggle('active');
                });
            }
        });
    </script>
</body>
</html>